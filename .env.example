# Server Configuration
PORT=8080
HOST=0.0.0.0

# Database Configuration
# DB_DRIVER: sqlite (default), postgres, or mysql
DB_DRIVER=sqlite
# DB_PATH: SQLite database file path (used when DB_DRIVER=sqlite)
DB_PATH=data/lesstruct.db
# DB_DSN: PostgreSQL connection string (required when DB_DRIVER=postgres)
# Format: postgres://user:password@host:port/dbname?sslmode=disable
# DB_DSN=postgres://lesstruct:lesstruct@localhost:5432/lesstruct?sslmode=disable
# DB_DSN: MySQL connection string (required when DB_DRIVER=mysql)
# Format: user:password@tcp(host:port)/dbname?parseTime=true&multiStatements=true&charset=utf8mb4&collation=utf8mb4_general_ci
# NOTE: parseTime=true is REQUIRED — without it DATE/DATETIME columns scan as []byte, not time.Time
# NOTE: multiStatements=true is REQUIRED — without it golang-migrate cannot run migrations with multiple SQL statements
# DB_DSN=lesstruct:lesstruct@tcp(localhost:3306)/lesstruct?parseTime=true&multiStatements=true&charset=utf8mb4&collation=utf8mb4_general_ci
# DB_POOL_MAX_CONNS: Connection pool size for client-server drivers (default: 20, used with postgres and mysql)
# DB_POOL_MAX_CONNS=20
# TEST_POSTGRES_DSN: PostgreSQL connection string for integration tests (only used with -tags postgresql)
# TEST_POSTGRES_DSN=postgres://lesstruct:lesstruct@localhost:5432/lesstruct_test?sslmode=disable
# TEST_MYSQL_DSN: MySQL connection string for integration tests (only used with -tags mysql)
# TEST_MYSQL_DSN=lesstruct:lesstruct@tcp(localhost:3306)/lesstruct_test?parseTime=true&charset=utf8mb4&collation=utf8mb4_general_ci

# JWT Configuration
JWT_SECRET=change_this_secret_in_production

# Logging
LOG_LEVEL=info

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@example.com

# CORS Configuration
# Comma-separated list of allowed origins for Cross-Origin Resource Sharing
# Include the protocol (http/https), domain, and port if applicable
# Example: http://localhost:5173,http://localhost:3000,https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Site Configuration
# Base URL of the site (used for email verification links, password reset links, etc.)
SITE_URL=http://localhost:8080

# Development Mode
# Set to true to proxy frontend requests to dev servers instead of embedded assets
DEV_MODE=false
ADMIN_DEV_URL=http://localhost:5173

# Rate Limiting
# Master toggle for rate limiting (set false to disable)
RATE_LIMIT_ENABLED=true
# Requests per minute for authentication endpoints (login, register, forgot-password, reset-password)
RATE_LIMIT_AUTH_PER_MINUTE=5
# Requests per minute for authenticated API endpoints
RATE_LIMIT_API_PER_MINUTE=100
# Requests per minute for public content delivery endpoints
RATE_LIMIT_PUBLIC_PER_MINUTE=60

# AI Image Generation (optional)
# Set AI_IMAGE_GENERATION_API_KEY to enable AI image generation in the admin panel
# When enabled, a "Generate with AI" button appears in the Media Library and Content Editor
# Supported models:
#   Google Gemini (prefix "gemini-"): gemini-3.1-flash-image, gemini-3-pro-image, gemini-2.5-flash-image
#   Google Imagen 4: imagen-4.0-generate-001, imagen-4.0-fast-generate-001, imagen-4.0-ultra-generate-001
#   GPT Image: gpt-image-1, gpt-image-1-mini, gpt-image-1.5, gpt-image-2
AI_IMAGE_GENERATION_API_KEY=
AI_IMAGE_GENERATION_MODEL=imagen-4.0-fast-generate-001
AI_IMAGE_GENERATION_SIZE=
AI_IMAGE_GENERATION_ASPECT_RATIO=

# AI Text Generation (optional)
# Set AI_TEXT_GENERATION_API_KEY to enable AI text enhancement and translation in the admin panel
# Works with any OpenAI-compatible API (OpenAI, OpenRouter, Together, Groq, Ollama, etc.)
# AI_TEXT_GENERATION_BASE_URL is optional — defaults to OpenAI's API; set it for other providers
# Example for OpenRouter: AI_TEXT_GENERATION_BASE_URL=https://openrouter.ai/api/v1
# Example for Ollama: AI_TEXT_GENERATION_BASE_URL=http://localhost:11434/v1
AI_TEXT_GENERATION_API_KEY=
AI_TEXT_GENERATION_BASE_URL=
# AI_TEXT_GENERATION_MODEL is the chat model to use (defaults to gpt-5-mini)
# Examples by provider:
#   OpenAI:          gpt-5.4-mini, gpt-5-mini
#   OpenRouter:      openai/gpt-5.4-mini, anthropic/claude-sonnet-4.6, google/gemini-3.5-flash
#   Together AI:     meta-llama/Llama-4-Maverick-17B-128E-Instruct-FP8
#   Groq:            llama-3.3-70b-versatile, mixtral-8x7b-32768
#   Ollama (local):  llama3, mistral, gemma3
AI_TEXT_GENERATION_MODEL=gpt-5-mini
