# Copy this file to .env.local and fill in values. .env.local is gitignored.
#
# The capture script reads ONLY from this file (it does not inherit your shell
# env), so this is the single source of truth for the pipeline. Never commit
# real credentials — .env.local stays local.

# Base URL of a running Lesstruct instance with sample content.
LESSTRUCT_URL=http://localhost:8080

# An admin account on that instance. Used to log into the admin SPA so the
# admin-panel scenes can be captured. The demo auto-creates admin/admin on
# first start and forces a password change, so use whatever you changed it to.
LESSTRUCT_ADMIN_USERNAME=admin
LESSTRUCT_ADMIN_PASSWORD=changeme
